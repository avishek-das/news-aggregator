# ── Required: Supabase ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.obnlucnwlkijttmleukx.supabase.co:5432/postgres
SUPABASE_URL=https://obnlucnwlkijttmleukx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
SUPABASE_SERVICE_KEY=your-service-role-key-from-supabase-dashboard

# ── Required: Frontend API base URL ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Optional: CORS (comma-separated origins) ─────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Optional: LLM (Phase 1.6) ────────────────────────────────
# Dev/test: Gemini Flash 1.5 is free — get key at aistudio.google.com
LLM_MODEL=gemini/gemini-1.5-flash
LLM_HIGH_SIGNAL_MODEL=gemini/gemini-1.5-flash
GEMINI_API_KEY=your-gemini-api-key

# Prod: Claude (switch by changing LLM_MODEL, no code changes)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_HIGH_SIGNAL_MODEL=claude-sonnet-4-6
DAILY_LLM_COST_CAP_USD=0.00

# ── Optional: App ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Optional: Reddit API (Phase 1.4) ─────────────────────────
# REDDIT_CLIENT_ID=your-reddit-client-id
# REDDIT_CLIENT_SECRET=your-reddit-client-secret
